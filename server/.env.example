# Primary AI provider — get a free key at https://console.groq.com
GROQ_API_KEY=

PORT=5000
# Leave CLIENT_ORIGIN blank in dev to allow any localhost port (Vite may pick 5174 etc.)
# CLIENT_ORIGIN=http://localhost:5173

# Auth — any long random string. Change before deploying.
JWT_SECRET=change-me-to-a-long-random-string

# Cross-encoder re-ranker — set 0 to skip (faster boot, slightly worse retrieval).
RERANKER_ENABLED=1

# Optional — local LLM fallback (auto-detected if Ollama is running).
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# MongoDB Atlas — stores users, hashed passwords, and chat history.
# Get a free M0 cluster at https://www.mongodb.com/cloud/atlas
# URI format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Leave MONGODB_URI blank only for local dev (uses in-memory store — lost on restart).
MONGODB_URI=
MONGODB_DB=seelenruh
