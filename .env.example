
# Seelenruh — environment variables
# Copy this file to server/.env and fill in the values.
# Never commit the real .env to version control. Use .env.example as a template.    


# Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=gsk_...

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be 32+ random characters. NEVER use the default placeholder in production.
JWT_SECRET=change-me-to-a-32-byte-random-string


# Database
# MongoDB Atlas connection string (leave blank to use in-memory dev fallback)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=seelenruh


# Redis (rate-limit persistence)
# Leave blank to use in-memory counters (resets on restart, fine for single instance)
REDIS_URL=redis://localhost:6379/0


# Email
# Without these, verification and reset emails are only printed to the server console.
# APP_BASE_URL must match your actual deployment URL so links in emails work.
APP_BASE_URL=https://your-app.hf.space

# --- Option A: Gmail (recommended, no custom domain needed) ---
# 1. Enable 2-Step Verification on your Google account.
# 2. Go to https://myaccount.google.com/apppasswords → generate a 16-char App Password.
# 3. Use that App Password below (NOT your regular Gmail password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM=your-gmail@gmail.com

# --- Option B: Resend (free tier — 100 emails/day, no domain needed for testing) ---
# Sign up at https://resend.com, create an API key, set it here.
# Free tier sends from onboarding@resend.dev — upgrade to send from your own domain.
# RESEND_API_KEY=re_...
# SMTP_FROM=onboarding@resend.dev

# --- Option C: SendGrid ---
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.xxx...
# SMTP_FROM=noreply@your-domain.com


# Observability 
SEELENRUH_ENV=prod          # "dev" | "prod"
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
# Sentry DSN for error tracking (optional)
SENTRY_DSN=


# Optional LLM fallbacks 
# Anthropic — used as 3rd-tier fallback after Groq + Ollama
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama — local LLM (2nd-tier fallback). Point at your Ollama instance.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b


# Optional features
# Brave Search API for real-time web results (https://api.search.brave.com)
BRAVE_SEARCH_KEY=

# ElevenLabs neural TTS — find your voice ID in the ElevenLabs dashboard
ELEVENLABS_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Admin key for /api/admin/* endpoints (ingest, delete, rollback RAG chunks)
# Generate with: python -c "import secrets; print(secrets.token_hex(24))"
ADMIN_KEY=


# CORS
# In production (Docker / reverse proxy), set this to your exact frontend origin.
# When set, it overrides DEV_ALLOWED_PORTS completely.
# CLIENT_ORIGIN=https://your-domain.com

# In dev, list the ports the Vite dev server and API run on (comma-separated).
DEV_ALLOWED_PORTS=5173,5000,3000


# Tuning
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
MAX_LOGIN_ATTEMPTS=10
MAX_HISTORY_TOKENS=6000
